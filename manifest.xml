<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/2008/11/05" xsi:type="TaskPaneApp">
  <Id>88dd7e69-9fc2-4ff1-abe0-3df420e2cffb</Id>
  <Version>1.0.0</Version>
  <ProviderName>Frankikoch</ProviderName>
  <DefaultLocale>es-ES</DefaultLocale>
  <DisplayName DefaultValue="Excel AI"/>
  <Description DefaultValue="AI Assistant for Excel"/>
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="WorkbookApi"/>
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://frankikoch.github.io/excel-ai-addin/index.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <FormSettings>
    <Form xsi:type="TaskPaneForm">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://frankikoch.github.io/excel-ai-addin/index.html"/>
        <RequestedWidth>450</RequestedWidth>
        <RequestedHeight>600</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
</OfficeApp>
