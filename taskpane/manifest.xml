<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/officeapp/2008/11/05" 
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
           xsi:type="TaskpaneApp">
  
  <Id>excel-ai-addin-v1</Id>
  <Version>1.0.0</Version>
  <ProviderName>franki</ProviderName>
  <DefaultLocale>es-ES</DefaultLocale>
  <DisplayName DefaultValue="Excel AI"/>
  <Description DefaultValue="AI Assistant powered by OpenCode"/>
  
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>
  
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="WorkbookApi"/>
    </Sets>
  </Requirements>
  
  <DefaultSettings>
    <SourceLocation>index.html</SourceLocation>
  </DefaultSettings>
  
  <Permissions>ReadDocument</Permissions>
  
  <DesktopFormFactor>
    <ExtensionPoint xsi:type="Taskpane">
      <SourceLocation>index.html</SourceLocation>
    </ExtensionPoint>
  </DesktopFormFactor>
  
</OfficeApp>
